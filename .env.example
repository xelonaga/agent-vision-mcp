# agent-vision-mcp 环境变量配置模板
# 复制此文件为 .env 并按需修改（仅供本地开发参考，MCP 运行时通过客户端配置注入环境变量）

# [必填] 视觉 API 的密钥
VISION_API_KEY=sk-your-key-here

# [可选] OpenAI 兼容 API 的地址（默认为 OpenAI 官方）
VISION_BASE_URL=https://api.openai.com/v1

# [可选] 使用的视觉模型名称（默认 gpt-4o）
VISION_MODEL_NAME=gpt-4o

# [可选] 最大输出 token 数（默认 1024）
VISION_MAX_TOKENS=1024

# [可选] 图片最大大小（字节，默认 20MB = 20971520）
VISION_MAX_IMAGE_SIZE=20971520

# [可选] 是否启用缓存（默认 false）
VISION_CACHE_ENABLED=false

# [可选] 缓存目录（默认使用系统临时目录）
# VISION_CACHE_DIR=/tmp/agent-vision-cache
